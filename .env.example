# API do backend (obrigatório para o frontend chamar a API)
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001/api/v1

# Nome da app na UI (opcional)
# NEXT_PUBLIC_APP_NAME=Stokio - Gestão Inteligente de Abrigos

# Logo nos relatórios PDF e fallback de branding (opcional)
# NEXT_PUBLIC_LOGO_URL=/logo.png

# Mesmo valor que R2_PUBLIC_BASE_URL no backend (URL pública do bucket, sem / no fim).
# Com R2 definido, o fallback do logo na UI e nos PDFs inclui {NEXT_PUBLIC_R2_PUBLIC_BASE_URL}/default_logo.png
# NEXT_PUBLIC_R2_PUBLIC_BASE_URL=https://pub-xxxxx.r2.dev

# Override opcional: só URL https completa substitui o default no R2
# NEXT_PUBLIC_APP_LOGO_URL=

# Chave pública opcional (se a API exigir header X-API-Key no browser)
# NEXT_PUBLIC_X_API_KEY=

# API do backend (obrigatório para o frontend chamar a API)
VITE_API_BASE_URL=http://localhost:3001/api/v1

# Mesmo valor que R2_PUBLIC_BASE_URL no backend (URL pública do bucket porto-assets, sem / no fim).
# Com isso, o fallback do logo na UI e nos PDFs é: {VITE_R2_PUBLIC_BASE_URL}/default_logo.png
# Envie o ficheiro default_logo.png (ex.: a partir de frontend/public/) para a raiz do bucket.
# VITE_R2_PUBLIC_BASE_URL=https://pub-xxxxx.r2.dev

# Override opcional: só URL https completa substitui o default no R2.
# Caminhos tipo /default_logo.png no .env não bloqueiam mais o R2 quando VITE_R2_PUBLIC_BASE_URL está definido.
# VITE_PUBLIC_APP_LOGO_URL=

# Override opcional só para PDFs (relatórios). Se vazio, usa o mesmo fallback que a UI (R2 ou /default_logo.png).
# VITE_LOGO_URL=

# Desenvolvimento com proxy Docker (porta 80) — alinhar com abrigo/.env / compose
NEXT_PUBLIC_API_BASE_URL=http://localhost/api/v1

# Se correr o frontend contra o backend na porta do host (sem proxy):
# NEXT_PUBLIC_API_BASE_URL=http://localhost:3001/api/v1

NEXT_PUBLIC_APP_NAME=
NEXT_PUBLIC_LOGO_URL=
NEXT_PUBLIC_APP_LOGO_URL=
NEXT_PUBLIC_R2_PUBLIC_BASE_URL=

# LGPD: URL externa da política (opcional; default /privacidade)
NEXT_PUBLIC_PRIVACY_POLICY_URL=

# Analytics opcional (só carrega com consentimento analítico)
NEXT_PUBLIC_GA_MEASUREMENT_ID=
